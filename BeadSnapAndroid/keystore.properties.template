# Copy this file to "keystore.properties" (same folder) and fill in your values.
# The real keystore.properties is gitignored and must NEVER be committed.
#
# storeFile can be an absolute path or a path relative to BeadSnapAndroid/.
# Keeping the .jks OUTSIDE the repo (e.g. your home folder) is safest.

storeFile=/absolute/path/to/beadsnap-release.jks
storePassword=your-keystore-password
keyAlias=beadsnap
keyPassword=your-key-password
